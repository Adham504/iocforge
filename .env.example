# =====================================================================
# IOCForge configuration — copy this file to ".env" and fill in keys.
# NEVER commit your real .env file. The .gitignore already excludes it.
# =====================================================================

# --- Threat Intelligence API keys (all optional) ---------------------
# VirusTotal v3 API key  -> https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AlienVault OTX API key -> https://otx.alienvault.com/api
OTX_API_KEY=

# AbuseIPDB API key      -> https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# abuse.ch Auth-Key (ThreatFox / MalwareBazaar / URLHaus)
# -> https://auth.abuse.ch/
ABUSECH_API_KEY=

# --- Behaviour -------------------------------------------------------
# Master switch for network enrichment (true/false)
ENABLE_ENRICHMENT=true

# Per-request HTTP timeout in seconds
REQUEST_TIMEOUT=20

# Delay between enrichment requests (seconds) to respect free rate limits
RATE_LIMIT_DELAY=1

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
